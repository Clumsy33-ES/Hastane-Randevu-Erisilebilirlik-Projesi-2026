# PostgreSQL bağlantı URL'si
# Örnek: postgresql://kullanici:sifre@localhost:5432/hospital_appointment_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/hospital_appointment_db

# İzin verilen CORS originleri (virgülle ayırarak girin)
# Örnek: https://my-frontend.vercel.app,https://www.my-frontend.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Güvenlik (JWT)
SECRET_KEY=gizli-bir-anahtar-kullanin-production-icin
ACCESS_TOKEN_EXPIRE_MINUTES=10080
