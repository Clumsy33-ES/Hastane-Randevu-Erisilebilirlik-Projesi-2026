{
  "expo": {
    "name": "Sağlık Ses",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EDED"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.erisimlirandevu.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#D32F2F"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Randevu alma sesli komutları için mikrofona erişim izni gereklidir.",
          "speechRecognitionPermission": "Söylediklerinizi algılayabilmek için ses tanıma izni gereklidir.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox", "com.google.android.tts"]
        }
      ],
      "./plugins/withAndroidSupportExclude.js",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "3b34965b-5337-4e3d-8e5e-3c74f169b1cf"
      }
    }
  }
}
